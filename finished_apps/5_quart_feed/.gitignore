# User-uploaded images (runtime data) — keep the folder, ignore its contents.
static/uploads/*
!static/uploads/.gitkeep

# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class

# Test / type / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.cache/

# Virtual environments
.venv/
venv/
env/

# OS / editor cruft
.DS_Store
*.swp
*~

# Logs
*.log
